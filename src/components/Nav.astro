---
import { branchMicrositeLinks } from "../config/branchSites.ts";

const normalizePath = (value) => {
  if (!value || value === "/") {
    return "/";
  }

  return value.endsWith("/") ? value.slice(0, -1) : value;
};

const pathname = normalizePath(Astro.url.pathname);
const isActive = (href) => normalizePath(href) === pathname;
const navId = "primary-navigation";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="HEART home">
      <img
        class="brand-logo"
        src="/images/heart-logo.png"
        alt="HEART logo"
        loading="eager"
      />
      <div class="brand-text">
        <span class="brand-name">HEART</span>
        <span class="brand-subtitle">Health Equity Advocacy Response Team</span>
      </div>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls={navId}
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id={navId} class="nav" aria-label="Primary navigation">
      <ul class="nav-list">
        <li>
          <a
            class={`nav-link ${isActive("/") ? "is-active" : ""}`}
            href="/"
            aria-current={isActive("/") ? "page" : undefined}
          >
            Home
          </a>
        </li>
        <li>
          <a
            class={`nav-link ${isActive("/about") ? "is-active" : ""}`}
            href="/about"
            aria-current={isActive("/about") ? "page" : undefined}
          >
            About
          </a>
        </li>
        <li>
          <a
            class={`nav-link ${isActive("/events") ? "is-active" : ""}`}
            href="/events"
            aria-current={isActive("/events") ? "page" : undefined}
          >
            Events
          </a>
        </li>
        <li>
          <a class="nav-link" href="/#get-involved">Get involved</a>
        </li>
      </ul>
    </nav>

    <div class="header-branch branch-dropdown">
      <button
        type="button"
        class="branch-dropdown-toggle"
        id="branch-toggle"
        aria-expanded="false"
        aria-haspopup="true"
        aria-controls="branch-menu"
      >
        Branch
        <span class="branch-dropdown-chevron" aria-hidden="true"></span>
      </button>
      <ul
        id="branch-menu"
        class="branch-dropdown-menu"
        role="menu"
        aria-labelledby="branch-toggle"
        hidden
      >
        <li role="none">
          <a
            class="branch-dropdown-item branch-dropdown-item--york"
            role="menuitem"
            href={branchMicrositeLinks.york}
            target="_blank"
            rel="noopener noreferrer"
          >
            York
          </a>
        </li>
        <li role="none">
          <a
            class="branch-dropdown-item branch-dropdown-item--western"
            role="menuitem"
            href={branchMicrositeLinks.western}
            target="_blank"
            rel="noopener noreferrer"
          >
            Western
          </a>
        </li>
        <!-- McMaster: hidden until the microsite is ready to go live — uncomment to show in the branch menu.
        <li role="none">
          <a
            class="branch-dropdown-item branch-dropdown-item--mcmaster"
            role="menuitem"
            href={branchMicrositeLinks.mcmaster}
            target="_blank"
            rel="noopener noreferrer"
          >
            McMaster
          </a>
        </li>
        -->
      </ul>
    </div>

    <a
      class={`button button-primary header-cta ${isActive("/join-branch") ? "is-active-cta" : ""}`}
      href="/join-branch"
      aria-current={isActive("/join-branch") ? "page" : undefined}
    >
      Join
    </a>
  </div>
</header>

<script>
  const menuToggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector(".nav");
  const navLinks = document.querySelectorAll(".nav-link");

  if (menuToggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
    const closeMenu = () => {
      nav.classList.remove("is-open");
      menuToggle.setAttribute("aria-expanded", "false");
    };

    menuToggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("is-open");
      menuToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });

    navLinks.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
        menuToggle.focus();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;

      if (
        target instanceof Node &&
        !nav.contains(target) &&
        !menuToggle.contains(target)
      ) {
        closeMenu();
      }
    });
  }

  const branchRoot = document.querySelector(".branch-dropdown");
  const branchToggle = document.querySelector("#branch-toggle");
  const branchMenu = document.querySelector("#branch-menu");

  if (
    branchRoot instanceof HTMLElement &&
    branchToggle instanceof HTMLButtonElement &&
    branchMenu instanceof HTMLElement
  ) {
    const closeBranch = () => {
      branchMenu.hidden = true;
      branchToggle.setAttribute("aria-expanded", "false");
      branchRoot.classList.remove("is-open");
    };

    branchToggle.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = branchRoot.classList.toggle("is-open");
      branchMenu.hidden = !isOpen;
      branchToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });

    branchMenu.querySelectorAll("a.branch-dropdown-item").forEach((item) => {
      item.addEventListener("click", () => {
        closeBranch();
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && branchRoot.classList.contains("is-open")) {
        closeBranch();
        branchToggle.focus();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (
        target instanceof Node &&
        !branchRoot.contains(target) &&
        branchRoot.classList.contains("is-open")
      ) {
        closeBranch();
      }
    });
  }
</script>
