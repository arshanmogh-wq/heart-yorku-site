---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "HEART — Health Equity Advocacy Response Team",
  description = "HEART is a York University student-led organization advancing health equity through advocacy, education, outreach, and community partnerships.",
  image = "/social-card.svg",
  noindex = false,
} = Astro.props;

const siteURL = new URL(Astro.site ?? Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const socialImageURL = new URL(image, siteURL);
const robots = noindex ? "noindex, nofollow" : "index, follow";
const isHomePage = Astro.url.pathname === "/";
const organizationJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "HEART",
  alternateName: "Health Equity Advocacy Response Team",
  url: siteURL.toString(),
  logo: new URL("/images/heart-logo.jpg", siteURL).toString(),
  email: "heartyorku@gmail.com",
  sameAs: ["https://www.instagram.com/heart_yorku"],
});
const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "HEART",
  alternateName: "Health Equity Advocacy Response Team",
  url: siteURL.toString(),
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="HEART" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={`${title} social preview`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={`${title} social preview`} />

    <link rel="icon" type="image/jpeg" href="/images/heart-logo.jpg" />
    <link rel="shortcut icon" href="/images/heart-logo.jpg" />
    <link rel="apple-touch-icon" href="/images/heart-logo.jpg" />
    <meta name="theme-color" content="#0B2239" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={organizationJsonLd}></script>
    {isHomePage && <script type="application/ld+json" set:html={websiteJsonLd}></script>}
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main" class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
