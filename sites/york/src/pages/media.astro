---
import BranchLayout from "../layouts/BranchLayout.astro";
import { branch } from "../site.ts";
---

<BranchLayout
  title={`Media — HEART ${branch.shortName}`}
  description={`Posters, photos, and graphics from HEART at ${branch.universityName}.`}
>
  <div class="page">
    <section class="section">
      <div class="container">
        <h1 class="section-title">Media · York branch</h1>
        <p class="section-lead">
          Campaign posters, event photos, and shareables for HEART at <strong>York</strong> live here.
          Assets are branch-specific so Western and McMaster can run their own look and messaging.
        </p>
        <p class="section-lead">
          <strong>Add files:</strong> place images under <code>sites/york/public/posters/</code> or
          <code>sites/york/public/gallery/</code>, then link them from this page when you are ready.
        </p>
        <p class="section-lead">
          Tag us when you post:
          <a href={branch.instagramUrl} target="_blank" rel="noopener noreferrer">{branch.instagramHandle}</a>.
        </p>
      </div>
    </section>
  </div>
</BranchLayout>
