---
import BranchLayout from "../layouts/BranchLayout.astro";
import { branch } from "../site.ts";
---

<BranchLayout
  title={`Executive team — HEART ${branch.shortName}`}
  description={`Leadership contacts for HEART at ${branch.universityName} (coming soon).`}
>
  <div class="page">
    <section class="section">
      <div class="container">
        <h1 class="section-title">Executive team · Western</h1>
        <p class="section-lead">
          Western’s presidents, VPs, and portfolio leads will be listed here with photos and mandates.
          Like the other branches, we keep exec info off the umbrella site so students know who represents
          <strong>London</strong> specifically.
        </p>
        <p class="section-lead">
          <strong>Status:</strong> roster coming after the next transition cycle. Faculty partners or sponsors
          can email <a href={`mailto:${branch.contactEmail}`}>{branch.contactEmail}</a> for signing authority
          questions in the meantime.
        </p>
      </div>
    </section>
  </div>
</BranchLayout>
